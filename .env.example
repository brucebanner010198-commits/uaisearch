#LLM_TIMEOUT_SECONDS=300
SEED_URLS=https://example-niche-blog.com/
# Empty TARGET_DOMAINS means Common Crawl backfill ingests all non-dark-web clearnet records in the chosen WET segment.
TARGET_DOMAINS=
